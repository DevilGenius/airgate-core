#!/usr/bin/env bash
# {{.SiteName}} × openclaw 一键配置脚本
#
# 该脚本由 airgate-core 在 /openclaw/install.sh 动态渲染，嵌入了当前站点的 BaseURL
# 与 provider 名称。脚本本身不访问 airgate admin API，只用用户提供的 API Key。
#
# 依赖：仅 bash 与 curl（macOS / Linux 均自带），无需额外语言或工具。
# 模型列表解析和 openclaw.json 渲染都由服务端完成，脚本只做交互和文件写入。

set -euo pipefail

AIRGATE_BASE="{{.BaseURL}}"
SITE_NAME="{{.SiteName}}"
CONFIG_DIR="${HOME}/.openclaw"
CONFIG_FILE="${CONFIG_DIR}/openclaw.json"

# ----------------------------------------------------------------------------
# 颜色与输出工具（不支持 tty 时自动降级为纯文本）
# ----------------------------------------------------------------------------
if [ -t 1 ]; then
  C_BOLD=$'\033[1m'
  C_GREEN=$'\033[32m'
  C_YELLOW=$'\033[33m'
  C_RED=$'\033[31m'
  C_DIM=$'\033[2m'
  C_RESET=$'\033[0m'
else
  C_BOLD= C_GREEN= C_YELLOW= C_RED= C_DIM= C_RESET=
fi

info()  { printf "%s\n" "$*"; }
ok()    { printf "${C_GREEN}✓${C_RESET} %s\n" "$*"; }
warn()  { printf "${C_YELLOW}!${C_RESET} %s\n" "$*"; }
die()   { printf "${C_RED}✗${C_RESET} %s\n" "$*" >&2; exit 1; }

# ----------------------------------------------------------------------------
# 前置检查
# ----------------------------------------------------------------------------
command -v curl >/dev/null 2>&1 || die "需要 curl，请先安装"

# 脚本走 `curl ... | bash` 时，bash 仍需要继续从 stdin 读取脚本本身，
# 不能直接 `exec < /dev/tty` 覆盖 fd 0；否则后续脚本内容会从 tty 读，表现成挂起。
# 这里单独开一个 fd 3 给交互式 read 使用。
INPUT_FD=0
if [ ! -t 0 ]; then
  if [ -r /dev/tty ]; then
    exec 3</dev/tty
    INPUT_FD=3
  else
    die "当前环境无法交互式读取输入，请下载脚本后再执行：curl -fsSL ${AIRGATE_BASE}/openclaw/install.sh -o install.sh && bash install.sh"
  fi
fi

# 统一的交互读取函数，避免后续每处都要判断 INPUT_FD。
read_input() {
  local __var="$1"
  if [ "${INPUT_FD}" -eq 0 ]; then
    read -r "${__var}" || true
  else
    read -r -u "${INPUT_FD}" "${__var}" || true
  fi
}

printf "${C_BOLD}%s${C_RESET}\n" "欢迎使用 ${SITE_NAME} × openclaw 一键配置工具"
printf "${C_DIM}%s${C_RESET}\n\n" "站点: ${AIRGATE_BASE}"

# ----------------------------------------------------------------------------
# 第 1 步：读取 API Key
# ----------------------------------------------------------------------------
API_KEY=""
while [ -z "${API_KEY}" ]; do
  printf "请粘贴你的 ${SITE_NAME} API Key (sk-...): "
  read_input API_KEY
  if [ -z "${API_KEY}" ]; then
    warn "API Key 不能为空，请重试"
  fi
done

# API Key 会被原样塞进 JSON 请求体，双引号/反斜杠会破坏 JSON 结构。
# 正规 sk-xxx 格式不会命中这两个字符，这里做一道安全闸。
case "${API_KEY}" in
  *\"*|*\\*)
    die "API Key 含有不支持的字符（双引号或反斜杠），请确认粘贴是否正确"
    ;;
esac

# 轻量校验：调 core 自己暴露的 /v1/usage 端点。这条路由直接由 core 处理（不经过
# 任何插件），用 sk-xxx 自鉴权并返回 { is_active, balance }：
#   - 有效 key：HTTP 200
#   - key 无效/过期/未绑定分组：HTTP 401
# 比 /v1/models（依赖插件声明路由）更可靠。
info "正在校验 API Key ..."
HTTP_CODE=$(curl -s -o /dev/null -w "%{http_code}" \
  -H "Authorization: Bearer ${API_KEY}" \
  "${AIRGATE_BASE}/v1/usage" || echo "000")
if [ "${HTTP_CODE}" != "200" ]; then
  die "API Key 校验失败 (HTTP ${HTTP_CODE})。请确认 Key 正确、未过期、未停用。"
fi
ok "API Key 校验通过"
echo

# ----------------------------------------------------------------------------
# 第 2 步：拉取模型列表（服务端已预处理成 pipe 分隔文本，无需在此解析 JSON）
# ----------------------------------------------------------------------------
MODELS_TXT=$(curl -fsSL "${AIRGATE_BASE}/openclaw/models.txt") \
  || die "无法从 ${AIRGATE_BASE}/openclaw/models.txt 拉取模型列表"

if [ -z "${MODELS_TXT}" ]; then
  die "模型列表为空，请联系管理员在管理面板配置 openclaw.models_preset"
fi

# 把每行的 id 存进索引数组（1-based，和展示序号对齐）。
# bash 3.2（macOS 自带）不支持 declare -A，这里只用普通索引数组。
MODEL_IDS=()
MODEL_COUNT=0
info "${C_BOLD}可选模型：${C_RESET}"
while IFS='|' read -r idx id label api caps; do
  [ -z "${idx}" ] && continue
  MODEL_IDS[${idx}]="${id}"
  MODEL_COUNT=${idx}
  suffix="  [${api}]"
  if [ -n "${caps}" ]; then
    suffix="${suffix} ${caps}"
  fi
  printf "  [%s] %s%s\n" "${idx}" "${label}" "${suffix}"
done <<< "${MODELS_TXT}"

if [ "${MODEL_COUNT}" -eq 0 ]; then
  die "模型列表解析失败，请联系管理员检查 openclaw.models_preset 格式"
fi
echo

# ----------------------------------------------------------------------------
# 第 3 步：让用户挑选（支持 "1 3" 或 "1,3"，回车默认选 1）
# ----------------------------------------------------------------------------
# 输出的是 JSON 数组片段：`"gpt-5.4","claude-sonnet-4-6"`，后面直接嵌进请求体。
SELECTED_JSON=""
while [ -z "${SELECTED_JSON}" ]; do
  printf "请输入要启用的模型编号（空格或逗号分隔，回车默认选 1）: "
  read_input RAW
  if [ -z "${RAW}" ]; then
    RAW="1"
  fi
  # 逗号换成空格，统一走 word splitting
  RAW_NORMALIZED=$(printf "%s" "${RAW}" | tr ',' ' ')

  PICKED_JSON=""
  PICKED_SEEN=" "
  VALID=1
  for tok in ${RAW_NORMALIZED}; do
    case "${tok}" in
      ''|*[!0-9]*)
        warn "输入含非数字: ${tok}"
        VALID=0
        break
        ;;
    esac
    if [ "${tok}" -lt 1 ] || [ "${tok}" -gt "${MODEL_COUNT}" ]; then
      warn "编号越界: ${tok}（合法范围 1-${MODEL_COUNT}）"
      VALID=0
      break
    fi
    # 简单去重（避免用户输 "1 1 2" 时产生重复项）
    case "${PICKED_SEEN}" in
      *" ${tok} "*) continue ;;
    esac
    PICKED_SEEN="${PICKED_SEEN}${tok} "
    model_id="${MODEL_IDS[${tok}]}"
    if [ -z "${PICKED_JSON}" ]; then
      PICKED_JSON="\"${model_id}\""
    else
      PICKED_JSON="${PICKED_JSON},\"${model_id}\""
    fi
  done

  if [ "${VALID}" -eq 1 ] && [ -n "${PICKED_JSON}" ]; then
    SELECTED_JSON="${PICKED_JSON}"
  fi
done

# ----------------------------------------------------------------------------
# 第 4 步：请求服务端渲染 openclaw.json
# ----------------------------------------------------------------------------
mkdir -p "${CONFIG_DIR}"
if [ -f "${CONFIG_FILE}" ]; then
  BACKUP="${CONFIG_FILE}.bak.$(date +%s)"
  cp "${CONFIG_FILE}" "${BACKUP}"
  warn "已备份旧配置到 ${BACKUP}"
fi

REQ_BODY=$(printf '{"api_key":"%s","selected_ids":[%s]}' "${API_KEY}" "${SELECTED_JSON}")
TMP_OUT="${CONFIG_FILE}.new"

# 用 curl 的 -w 拿到 HTTP 状态码，同时把响应体写到临时文件；
# 失败时响应体是服务端返回的纯文本错误信息，一并展示给用户排查。
HTTP_CODE=$(curl -s -o "${TMP_OUT}" -w "%{http_code}" \
  -X POST \
  -H "Content-Type: application/json" \
  -d "${REQ_BODY}" \
  "${AIRGATE_BASE}/openclaw/render-config" || echo "000")

if [ "${HTTP_CODE}" != "200" ]; then
  ERR_MSG=$(cat "${TMP_OUT}" 2>/dev/null || echo "")
  rm -f "${TMP_OUT}"
  die "渲染配置失败 (HTTP ${HTTP_CODE}): ${ERR_MSG}"
fi

mv "${TMP_OUT}" "${CONFIG_FILE}"
ok "已写入 ${CONFIG_FILE}"
echo
info "${C_BOLD}下一步：${C_RESET}"
info "  1. 安装 openclaw:    npm install -g openclaw@latest"
info "  2. 启动 gateway:     openclaw gateway"
echo
