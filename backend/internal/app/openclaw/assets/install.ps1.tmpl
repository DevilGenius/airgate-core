# {{.SiteName}} × openclaw 一键配置脚本（Windows PowerShell 版）
#
# 该脚本由 airgate-core 在 /openclaw/install.ps1 动态渲染，嵌入当前站点 BaseURL。
#
# 用法：
#   iwr -useb {{.BaseURL}}/openclaw/install.ps1 | iex
#
# 依赖：PowerShell 5+（Windows 10/11 自带）。无需 python / jq / curl 等外部工具。
# 模型列表解析和 openclaw.json 渲染都在服务端完成，客户端只做交互和文件写入。

$ErrorActionPreference = 'Stop'

# PowerShell 5.1 默认禁用 TLS 1.2，而多数生产站点强制 HTTPS/TLS1.2+，
# 为避免 TLS 握手失败导致的 "请求被中止" 错误，开头显式启用一次。
try {
    [Net.ServicePointManager]::SecurityProtocol = [Net.ServicePointManager]::SecurityProtocol -bor [Net.SecurityProtocolType]::Tls12
} catch {
    # PowerShell Core 7+ 不需要也改不了这个属性，忽略即可。
}

if ($PSVersionTable.PSVersion.Major -lt 5) {
    Write-Host "需要 PowerShell 5 或更高版本，当前版本: $($PSVersionTable.PSVersion)" -ForegroundColor Red
    exit 1
}

$AirgateBase = '{{.BaseURL}}'
$SiteName    = '{{.SiteName}}'
$ConfigDir   = Join-Path $env:USERPROFILE '.openclaw'
$ConfigFile  = Join-Path $ConfigDir 'openclaw.json'

# ----------------------------------------------------------------------------
# 输出工具（Write-Host 的 -ForegroundColor 在 PS 5.1 上原生可用，不依赖 ANSI）
# ----------------------------------------------------------------------------
function Write-Info { param([string]$Message) Write-Host $Message }
function Write-Ok   { param([string]$Message) Write-Host "[OK] $Message" -ForegroundColor Green }
function Write-Warn { param([string]$Message) Write-Host "[!]  $Message" -ForegroundColor Yellow }
function Stop-Die   { param([string]$Message) Write-Host "[X]  $Message" -ForegroundColor Red; exit 1 }

Write-Host ""
Write-Host "欢迎使用 $SiteName x openclaw 一键配置工具" -ForegroundColor White
Write-Host "站点: $AirgateBase" -ForegroundColor DarkGray
Write-Host ""

# ----------------------------------------------------------------------------
# 第 1 步：读取 API Key
# ----------------------------------------------------------------------------
$apiKey = ''
while ([string]::IsNullOrWhiteSpace($apiKey)) {
    $apiKey = (Read-Host "请粘贴你的 $SiteName API Key (sk-...)").Trim()
    if ([string]::IsNullOrWhiteSpace($apiKey)) {
        Write-Warn "API Key 不能为空，请重试"
    }
}

# API Key 会被原样塞进 JSON 请求体，双引号/反斜杠会破坏 JSON 结构。
# 正规 sk-xxx 格式不会命中这两个字符，这里做一道安全闸。
if ($apiKey -match '["\\]') {
    Stop-Die "API Key 含有不支持的字符（双引号或反斜杠），请确认粘贴是否正确"
}

# ----------------------------------------------------------------------------
# 第 2 步：校验 API Key —— 调 core 自暴露的 /v1/usage 端点
# ----------------------------------------------------------------------------
Write-Info "正在校验 API Key ..."
try {
    $null = Invoke-RestMethod -Uri "$AirgateBase/v1/usage" `
        -Headers @{ Authorization = "Bearer $apiKey" } `
        -Method Get `
        -UseBasicParsing
} catch {
    $statusCode = ''
    if ($_.Exception.Response) {
        $statusCode = " (HTTP $([int]$_.Exception.Response.StatusCode))"
    }
    Stop-Die "API Key 校验失败$statusCode。请确认 Key 正确、未过期、未停用。"
}
Write-Ok "API Key 校验通过"
Write-Host ""

# ----------------------------------------------------------------------------
# 第 3 步：拉取模型列表（服务端已预处理成 pipe 分隔文本，无需解析 JSON）
# ----------------------------------------------------------------------------
try {
    $modelsText = (Invoke-RestMethod -Uri "$AirgateBase/openclaw/models.txt" -Method Get -UseBasicParsing)
} catch {
    Stop-Die "无法从 $AirgateBase/openclaw/models.txt 拉取模型列表: $($_.Exception.Message)"
}
if ([string]::IsNullOrWhiteSpace($modelsText)) {
    Stop-Die "模型列表为空，请联系管理员在管理面板配置 openclaw.models_preset"
}

# 解析每一行：idx|id|label|api|caps
$modelIds = @()
Write-Host "可选模型：" -ForegroundColor White
foreach ($line in ($modelsText -split "`r?`n")) {
    if ([string]::IsNullOrWhiteSpace($line)) { continue }
    $parts = $line -split '\|'
    if ($parts.Count -lt 4) { continue }
    $idx   = $parts[0]
    $id    = $parts[1]
    $label = $parts[2]
    $api   = $parts[3]
    $caps  = if ($parts.Count -ge 5) { $parts[4] } else { '' }
    $modelIds += $id
    $suffix = "  [$api]"
    if (-not [string]::IsNullOrWhiteSpace($caps)) {
        $suffix = "$suffix $caps"
    }
    Write-Host "  [$idx] $label$suffix"
}

if ($modelIds.Count -eq 0) {
    Stop-Die "模型列表解析失败，请联系管理员检查 openclaw.models_preset 格式"
}
Write-Host ""

# ----------------------------------------------------------------------------
# 第 4 步：让用户挑选（支持 "1 3" 或 "1,3"，回车默认选 1）
# ----------------------------------------------------------------------------
$selectedIds = @()
while ($selectedIds.Count -eq 0) {
    $raw = (Read-Host "请输入要启用的模型编号（空格或逗号分隔，回车默认选 1）").Trim()
    if ([string]::IsNullOrWhiteSpace($raw)) { $raw = '1' }

    $tokens = ($raw -replace ',', ' ') -split '\s+' | Where-Object { $_ }
    $picked = @()
    $valid = $true
    foreach ($tok in $tokens) {
        if ($tok -notmatch '^\d+$') {
            Write-Warn "输入含非数字: $tok"
            $valid = $false; break
        }
        $n = [int]$tok
        if ($n -lt 1 -or $n -gt $modelIds.Count) {
            Write-Warn "编号越界: $tok（合法范围 1-$($modelIds.Count)）"
            $valid = $false; break
        }
        $id = $modelIds[$n - 1]
        if ($picked -notcontains $id) {
            $picked += $id
        }
    }

    if ($valid -and $picked.Count -gt 0) {
        $selectedIds = $picked
    }
}

# ----------------------------------------------------------------------------
# 第 5 步：请求服务端渲染 openclaw.json 并落盘
# ----------------------------------------------------------------------------
if (-not (Test-Path $ConfigDir)) {
    New-Item -ItemType Directory -Path $ConfigDir -Force | Out-Null
}

if (Test-Path $ConfigFile) {
    $ts = [int][double]::Parse((Get-Date -UFormat %s))
    $backup = "$ConfigFile.bak.$ts"
    Copy-Item -Path $ConfigFile -Destination $backup -Force
    Write-Warn "已备份旧配置到 $backup"
}

# ConvertTo-Json 会自动转义 apiKey / model id 里的特殊字符，比 shell 拼字符串安全。
$body = @{
    api_key      = $apiKey
    selected_ids = $selectedIds
} | ConvertTo-Json -Compress

try {
    $resp = Invoke-WebRequest -Uri "$AirgateBase/openclaw/render-config" `
        -Method Post `
        -ContentType 'application/json' `
        -Body $body `
        -UseBasicParsing
} catch {
    $statusCode = ''
    if ($_.Exception.Response) {
        $statusCode = " (HTTP $([int]$_.Exception.Response.StatusCode))"
    }
    # 尝试把服务端返回的错误正文读出来，更有助于排查
    $errMsg = $_.Exception.Message
    if ($_.ErrorDetails -and $_.ErrorDetails.Message) {
        $errMsg = $_.ErrorDetails.Message
    }
    Stop-Die "渲染配置失败$statusCode: $errMsg"
}

# 用 UTF8 无 BOM 写出，避免 openclaw CLI 读 JSON 时踩到 BOM
$utf8NoBom = New-Object System.Text.UTF8Encoding $false
[System.IO.File]::WriteAllText($ConfigFile, $resp.Content, $utf8NoBom)

Write-Ok "已写入 $ConfigFile"
Write-Host ""
Write-Host "下一步：" -ForegroundColor White
Write-Host "  1. 安装 openclaw:    npm install -g openclaw@latest"
Write-Host "  2. 启动 gateway:     openclaw gateway"
Write-Host ""
