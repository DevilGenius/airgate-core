server:
  host: 0.0.0.0                  # 监听地址：0.0.0.0=所有接口 / 127.0.0.1=仅本机
  port: 9517
  mode: release                  # debug / release
  trusted_proxies: []            # 反向代理 IP/CIDR；为空表示不信任 X-Forwarded-For

database:
  host: localhost
  port: 5432
  user: airgate
  password: ""                   # 必须修改！或设置环境变量 DB_PASSWORD
  dbname: airgate
  sslmode: disable

redis:
  host: localhost
  port: 6379
  password: ""                   # 或设置环境变量 REDIS_PASSWORD
  db: 0

jwt:
  secret: ""                     # 必须修改！或设置环境变量 JWT_SECRET
  expire_hour: 24

security:
  api_key_secret: ""             # 必须修改！API Key 加密密钥（32 字节 hex，即 64 字符）
                                 # 生成方法：openssl rand -hex 32；或设置环境变量 API_KEY_SECRET

log:
  level: "info"                  # debug / info / warn / error；core 设置会自动透传给所有插件
                                 # 或设置环境变量 LOG_LEVEL
  format: "text"                 # text（人看）/ json（对接 Loki / ELK / Datadog）
                                 # 或设置环境变量 LOG_FORMAT

monitor:
  request_trace_enabled: false   # 最终错误原始请求追踪；也可用 MONITOR_REQUEST_TRACE_ENABLED=true

plugins:
  dir: data/plugins
  dev: []
  # dev:
  #   - name: airgate-openai
  #     path: ../../airgate-openai/backend
